{
  "expo": {
    "name": "CapitalQuest",
    "slug": "capitalquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "capitalquest",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capitalquest.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for profile photos",
        "NSMicrophoneUsageDescription": "Used for voice meetings"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.capitalquest.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo.png",
      "name": "CapitalQuest",
      "shortName": "CapitalQuest",
      "description": "Master the stock market risk-free. Trade with real-time prices, compete on leaderboards, and level up your investing skills — completely free.",
      "lang": "en",
      "themeColor": "#00B3E6",
      "backgroundColor": "#0A0E1A"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#00D4AA"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
