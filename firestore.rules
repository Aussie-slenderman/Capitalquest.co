rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ADMIN OVERRIDE ────────────────────────────────────────────────────
    // theosmales1@gmail.com has full read/write across EVERY collection,
    // including any new collections added in the future. This rule is
    // evaluated alongside (OR'd with) the per-collection rules below.
    match /{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == 'theosmales1@gmail.com';
    }

    // Users: allow unauthenticated username lookup for login;
    // full profile read requires auth
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId
                   || request.auth.token.email == 'theosmales1@gmail.com';
      // Allow any authenticated user to update social fields on other users
      allow update: if request.auth != null;
      // Allow unauthenticated password reset (only storedPassword field)
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['storedPassword']);

      match /notifications/{notifId} {
        allow read, delete: if request.auth.uid == userId
                            || request.auth.token.email == 'theosmales1@gmail.com';
        allow create: if request.auth != null;
      }
    }

    // Portfolios: any authenticated user can read (needed for leaderboard);
    // only owner can write
    match /portfolios/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId
                   || request.auth.token.email == 'theosmales1@gmail.com';
    }

    // Portfolio history: owner/admin read-write on all nested docs
    match /portfolioHistory/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId
                         || request.auth.token.email == 'theosmales1@gmail.com';
    }

    // Transactions: owner only
    match /transactions/{txId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // Leaderboard: all authenticated users can read; write only your own entry
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Clubs: any authenticated user can read and join (update memberIds);
    // only owner or members can update other fields; owner can delete
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;
    }

    // Chat rooms: any authenticated user can read/update
    // (joining a club adds you to participantIds)
    match /chatRooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;

      // Messages in a room
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }

    // Trade proposals: sender or receiver
    match /tradeProposals/{proposalId} {
      allow read: if request.auth.uid == resource.data.fromUserId
                  || request.auth.uid == resource.data.toUserId;
      allow create: if request.auth.uid == request.resource.data.fromUserId;
      allow update: if request.auth.uid == resource.data.toUserId;
    }

    // Club invites: any authenticated user can create; sender or receiver can read/update/delete
    match /clubInvites/{inviteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Friend requests: any authenticated user can create; sender or receiver can read/update/delete
    match /friendRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Password reset requests: any user can create (even unauthenticated for forgot-password)
    match /passwordResetRequests/{reqId} {
      allow create: if true;
      allow read, update: if true;
    }
  }
}
